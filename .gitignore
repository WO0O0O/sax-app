## Xcode / Apple Professional Defaults
# Build results
build/
DerivedData/

# Personal User Data (Breakpoints, Window layout, etc.)
# These ARE the ones we want to ignore
xcuserdata/
*.xcuserstate
project.xcworkspace/xcuserdata/
*.xcscmblueprint

# Swift Package Manager
.swiftpm/xcode/package.xcworkspace/contents.xcworkspacedata
.swiftpm/xcode/xcuserdata/

# Misc
.DS_Store
*.swp
*.lock
